{
  "name": "gallery-server",
  "version": "1.0.0",
  "description": "Self-hosted photo & video gallery server for Raspberry Pi",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "scan": "node -e \"const {scanMedia} = require('./src/scanner'); scanMedia().then(() => process.exit(0))\""
  },
  "keywords": ["gallery", "photos", "videos", "self-hosted"],
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "express": "^4.21.2",
    "fluent-ffmpeg": "^2.1.3",
    "mime-types": "^2.1.35",
    "sharp": "^0.33.5"
  }
}
